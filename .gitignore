# =============================================================================
# Zola Static Site — .gitignore
# Strategy: public/ is committed manually (no CI). See .github/ when switching.
# =============================================================================

# Zola build output — generated by `zola build`, deployed via CI
public/

# Zola build cache
.zola_cache/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.fuse_hidden*
.Trash-*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Editor — VS Code
.vscode/
*.code-workspace

# Editor — JetBrains (IDEA, WebStorm, etc.)
.idea/
*.iml

# Editor — Vim / Neovim
*.swp
*.swo
*.swn
Session.vim

# Editor — Emacs
*~
\#*\#
.emacs.desktop

# Node (if any tooling is added later)
node_modules/
npm-debug.log*

# Sass cache (if compile_sass is enabled later)
.sass-cache/

# Automatically generated OG images
static/images/og/

# Temporary generated project data
content/projects/new_data.toml
